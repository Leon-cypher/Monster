rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // phases: anyone can read (community cards), only backend writes
    match /phases/{phaseId} {
      allow read: if true;
      allow write: if false;
    }

    // draws: anyone can read (draw records), only backend writes
    match /draws/{drawId} {
      allow read: if true;
      allow write: if false;
    }

    // playerScores, pointTransactions, pos_records: backend only
    // All player queries go through Cloud Functions (getUserPoints etc.)
    match /playerScores/{docId} {
      allow read, write: if false;
    }
    match /pointTransactions/{docId} {
      allow read, write: if false;
    }
    match /pos_records/{docId} {
      allow read, write: if false;
    }

    // adminaccount: fully blocked — verification done via Cloud Function
    match /adminaccount/{docId} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
